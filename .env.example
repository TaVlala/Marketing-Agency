# =============================================================================
# FRONTEND (Next.js) — copy to .env.local for local dev
# These SAME vars must also be added to Vercel: Project → Settings → Env Vars
# =============================================================================

# Payload CMS API URL (build-time only — used to fetch content during `next build`)
PAYLOAD_URL=http://localhost:3000

# Cloudinary cloud name (public — embedded in client bundle for image URLs)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Plausible Analytics domain (e.g. youragency.com)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Mailchimp embedded form action URL (public — used client-side)
# Get this from Mailchimp → Audience → Signup forms → Embedded forms
NEXT_PUBLIC_MAILCHIMP_URL=

# Formspree form endpoint URL (public — used client-side)
# e.g. https://formspree.io/f/xyzabcde
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Public site URL (used for sitemap and OG meta — e.g. https://youragency.com)
# Use your Vercel preview URL until you have a real domain
NEXT_PUBLIC_SITE_URL=

# =============================================================================
# GITHUB ACTIONS SECRET — set this in GitHub repo Settings → Secrets → Actions
# =============================================================================
# VERCEL_DEPLOY_HOOK=   # Vercel: Project → Settings → Git → Deploy Hooks
#                       # Only needed for CMS-triggered rebuilds

# =============================================================================
# PAYLOAD CMS (Railway only) — these NEVER go in the frontend .env
# =============================================================================
# Set these in Railway's environment variables panel, not here.
#
# DATABASE_URI=               # Railway PostgreSQL connection string (auto-provisioned)
# PAYLOAD_SECRET=             # Random secret for JWT (generate: openssl rand -hex 32)
# PAYLOAD_PUBLIC_SERVER_URL=  # Railway public URL for the Payload app
# CLOUDINARY_API_KEY=         # Cloudinary API key (server-side only)
# CLOUDINARY_API_SECRET=      # Cloudinary API secret (server-side only)
